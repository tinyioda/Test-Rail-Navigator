@section Scripts {
    <script>
        document.getElementById('renameEntryModal')?.addEventListener('show.bs.modal', function (event) {
            var button = event.relatedTarget;
            document.getElementById('renameEntryId').value = button.getAttribute('data-entry-id');
            document.getElementById('renameEntryName').value = button.getAttribute('data-entry-name');
        });

        document.getElementById('deleteEntryModal')?.addEventListener('show.bs.modal', function (event) {
            var button = event.relatedTarget;
            document.getElementById('deleteEntryId').value = button.getAttribute('data-entry-id');
            document.getElementById('deleteEntryName').textContent = button.getAttribute('data-entry-name');
        });

        document.getElementById('quickViewModal')?.addEventListener('show.bs.modal', function (event) {
            var btn = event.relatedTarget;
            var testId = btn.getAttribute('data-test-id');

            document.getElementById('qvTitle').textContent = btn.getAttribute('data-title');
            var badge = document.getElementById('qvStatusBadge');
            badge.textContent = btn.getAttribute('data-status');
            badge.className = 'badge ms-2 ' + btn.getAttribute('data-status-class');

            document.getElementById('qvTestId').textContent = 'T' + testId;
            document.getElementById('qvDetailLink').href = '/TestDetail/' + testId;
            document.getElementById('qvCaseId').textContent = 'C' + btn.getAttribute('data-case-id');
            document.getElementById('qvPriority').textContent = btn.getAttribute('data-priority') || '\u2014';
            document.getElementById('qvType').textContent = btn.getAttribute('data-type') || '\u2014';
            document.getElementById('qvEstimate').textContent = btn.getAttribute('data-estimate') || '\u2014';
            document.getElementById('qvRefs').textContent = btn.getAttribute('data-refs') || '\u2014';

            function toggleSection(sectionId, contentId, value) {
                var section = document.getElementById(sectionId);
                var content = document.getElementById(contentId);
                if (value) {
                    content.textContent = value;
                    section.classList.remove('d-none');
                } else {
                    section.classList.add('d-none');
                }
            }
            toggleSection('qvPrecondsSection', 'qvPreconds', btn.getAttribute('data-preconds'));
            toggleSection('qvStepsSection', 'qvSteps', btn.getAttribute('data-steps'));
            toggleSection('qvExpectedSection', 'qvExpected', btn.getAttribute('data-expected'));

            var loading = document.getElementById('qvResultsLoading');
            var empty = document.getElementById('qvResultsEmpty');
            var table = document.getElementById('qvResultsTable');
            var tbody = document.getElementById('qvResultsBody');
            loading.classList.remove('d-none');
            empty.classList.add('d-none');
            table.classList.add('d-none');
            tbody.innerHTML = '';

            var planId = @(Model.Plan?.Id ?? 0);
            fetch('?planId=' + planId + '&handler=Results&testId=' + testId)
                .then(function (r) { return r.json(); })
                .then(function (results) {
                    loading.classList.add('d-none');
                    if (!results || results.length === 0) {
                        empty.classList.remove('d-none');
                        return;
                    }
                    table.classList.remove('d-none');
                    var statusMap = { 1: ['Passed','bg-success'], 2: ['Blocked','bg-warning'], 3: ['Untested','bg-secondary'], 4: ['Retest','bg-info'], 5: ['Failed','bg-danger'] };
                    results.forEach(function (r) {
                        var tr = document.createElement('tr');
                        var info = statusMap[r.statusId] || ['Unknown','bg-secondary'];
                        tr.innerHTML = '<td><span class="badge ' + info[1] + '">' + info[0] + '</span></td>'
                            + '<td class="small">' + (r.comment || '<span class="text-muted">\u2014</span>') + '</td>'
                            + '<td class="small text-nowrap">' + r.createdOn + '</td>';
                        tbody.appendChild(tr);
                    });
                })
                .catch(function () {
                    loading.classList.add('d-none');
                    empty.textContent = 'Failed to load results.';
                    empty.classList.remove('d-none');
                });
        });

        document.getElementById('quickEditModal')?.addEventListener('show.bs.modal', function (event) {
            var btn = event.relatedTarget;
            document.getElementById('qeTitle').textContent = btn.getAttribute('data-title');
            document.getElementById('qeTestLabel').textContent = 'T' + btn.getAttribute('data-test-id') + ' / C' + btn.getAttribute('data-case-id');
            document.getElementById('qeCaseId').value = btn.getAttribute('data-case-id');
            document.getElementById('qeRunId').value = btn.getAttribute('data-run-id');
            var currentStatus = btn.getAttribute('data-status-id');
            var select = document.getElementById('qeStatusId');
            select.value = (currentStatus && currentStatus !== '3') ? currentStatus : '';
            document.getElementById('qeComment').value = '';
        });

        document.getElementById('quickCaseEditModal')?.addEventListener('show.bs.modal', function (event) {
            var btn = event.relatedTarget;
            document.getElementById('qcTitle').textContent = btn.getAttribute('data-title');
            document.getElementById('qcCaseId').value = btn.getAttribute('data-case-id');
            document.getElementById('qcCaseTitle').value = btn.getAttribute('data-title');
            var typeId = btn.getAttribute('data-type-id');
            document.getElementById('qcTypeId').value = (typeId && typeId !== '0') ? typeId : '';
            var priorityId = btn.getAttribute('data-priority-id');
            document.getElementById('qcPriorityId').value = (priorityId && priorityId !== '0') ? priorityId : '';
            document.getElementById('qcEstimate').value = btn.getAttribute('data-estimate') || '';
        });

        document.getElementById('removeTestModal')?.addEventListener('show.bs.modal', function (event) {
            var btn = event.relatedTarget;
            document.getElementById('pdRemoveTestCaseId').value = btn.getAttribute('data-case-id');
            document.getElementById('pdRemoveTestRunId').value = btn.getAttribute('data-run-id');
            document.getElementById('pdRemoveTestName').textContent = btn.getAttribute('data-title');
        });
    </script>
}
