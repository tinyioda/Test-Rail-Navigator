@page "{planId:int}"
@model PlanDetailModel
@{
    ViewData["Title"] = $"Plan - {Model.Plan?.Name}";
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-page="/Index">Projects</a></li>
        <li class="breadcrumb-item"><a asp-page="/Project" asp-route-projectId="@Model.ProjectId">@(Model.Project?.Name ?? "Project")</a></li>
        @if (Model.Milestone is not null)
        {
            @if (Model.ParentMilestone is not null)
            {
                <li class="breadcrumb-item"><a asp-page="/Project" asp-route-projectId="@Model.ProjectId" asp-route-milestoneId="@Model.ParentMilestone.Id">@Model.ParentMilestone.Name</a></li>
            }
            <li class="breadcrumb-item"><a asp-page="/Project" asp-route-projectId="@Model.ProjectId" asp-route-milestoneId="@Model.Milestone.Id">@Model.Milestone.Name</a></li>
        }
        <li class="breadcrumb-item active">@Model.Plan?.Name</li>
    </ol>
</nav>

<h1>@Model.Plan?.Name</h1>
@if (Model.Milestone is not null)
{
    <p class="text-muted">@Model.Milestone.Name</p>
}

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger alert-dismissible fade show">
        @Model.ErrorMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="alert alert-success alert-dismissible fade show">
        @Model.SuccessMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row">
    <!-- Left Panel: Milestone Plans & Runs -->
    @if (Model.Milestone is not null)
    {
        <div class="col-lg-3 col-md-4 mb-4">
            <div class="card h-100">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h6 class="mb-0">@Model.Milestone.Name</h6>
                    <a asp-page="/Project" asp-route-projectId="@Model.ProjectId" asp-route-milestoneId="@Model.Milestone.Id" class="btn btn-sm btn-outline-info">
                        Overview
                    </a>
                </div>
                <div class="card-body p-0" style="overflow-y: auto; max-height: 70vh;">
                    <!-- Open Test Plans -->
                    <div class="panel-section-label">
                        <h6 class="text-uppercase text-muted small fw-bold mb-0">
                            Open Plans
                            <span class="badge bg-success ms-1">@Model.OpenPlans.Count</span>
                        </h6>
                    </div>
                    @if (Model.OpenPlans.Count == 0)
                    {
                        <p class="text-muted small px-3 pb-2">No open test plans.</p>
                    }
                    else
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var plan in Model.OpenPlans)
                            {
                                var isSelected = plan.Id == Model.Plan?.Id;
                                <a asp-page="/PlanDetail" asp-route-planId="@plan.Id"
                                   class="list-group-item list-group-item-action px-3 py-2 @(isSelected ? "active" : "")">
                                    <div class="fw-semibold small">@plan.Name</div>
                                </a>
                            }
                        </div>
                    }

                    <!-- Open Test Runs -->
                    <div class="panel-section-label">
                        <h6 class="text-uppercase text-muted small fw-bold mb-0">
                            Open Runs
                            <span class="badge bg-success ms-1">@Model.OpenRuns.Count</span>
                        </h6>
                    </div>
                    @if (Model.OpenRuns.Count == 0)
                    {
                        <p class="text-muted small px-3 pb-2">No open test runs.</p>
                    }
                    else
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var run in Model.OpenRuns)
                            {
                                <a asp-page="/Tests" asp-route-runId="@run.Id"
                                   class="list-group-item list-group-item-action px-3 py-2">
                                    <div class="fw-semibold small">@run.Name</div>
                                </a>
                            }
                        </div>
                    }

                    @if (Model.ClosedPlans.Count > 0 || Model.ClosedRuns.Count > 0)
                    {
                        <hr class="my-0" />
                    }

                    @if (Model.ClosedPlans.Count > 0)
                    {
                        <!-- Closed Test Plans -->
                        <div class="panel-section-label">
                            <h6 class="text-uppercase text-muted small fw-bold mb-0">
                                Closed Plans
                                <span class="badge bg-secondary ms-1">@Model.ClosedPlans.Count</span>
                            </h6>
                        </div>
                        <div class="list-group list-group-flush">
                            @foreach (var plan in Model.ClosedPlans)
                            {
                                var isSelected = plan.Id == Model.Plan?.Id;
                                <a asp-page="/PlanDetail" asp-route-planId="@plan.Id"
                                   class="list-group-item list-group-item-action px-3 py-2 @(isSelected ? "active" : "")">
                                    <div class="@(isSelected ? "" : "text-muted") small">@plan.Name</div>
                                </a>
                            }
                        </div>
                    }

                    @if (Model.ClosedRuns.Count > 0)
                    {
                        <!-- Closed Test Runs -->
                        <div class="panel-section-label">
                            <h6 class="text-uppercase text-muted small fw-bold mb-0">
                                Closed Runs
                                <span class="badge bg-secondary ms-1">@Model.ClosedRuns.Count</span>
                            </h6>
                        </div>
                        <div class="list-group list-group-flush">
                            @foreach (var run in Model.ClosedRuns)
                            {
                                <a asp-page="/Tests" asp-route-runId="@run.Id"
                                   class="list-group-item list-group-item-action px-3 py-2">
                                    <div class="text-muted small">@run.Name</div>
                                </a>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    }

    <!-- Right Side: Plan Detail -->
    <div class="@(Model.Milestone is not null ? "col-lg-9 col-md-8" : "col-12")">

        @if (Model.Plan is not null)
        {
            var totalTests = Model.Plan.PassedCount + Model.Plan.FailedCount + Model.Plan.BlockedCount + Model.Plan.UntestedCount;
            var executedTests = Model.Plan.PassedCount + Model.Plan.FailedCount + Model.Plan.BlockedCount;

            @if (totalTests > 0)
            {
                var passedPct = (double)Model.Plan.PassedCount / totalTests * 100;
                var failedPct = (double)Model.Plan.FailedCount / totalTests * 100;
                var blockedPct = (double)Model.Plan.BlockedCount / totalTests * 100;
                var untestedPct = (double)Model.Plan.UntestedCount / totalTests * 100;

                var passRate = executedTests > 0
                    ? (double)Model.Plan.PassedCount / executedTests * 100
                    : 0;
                var completionRate = (double)executedTests / totalTests * 100;

                var confidenceLevel = passRate switch
                {
                    >= 90 => "High",
                    >= 70 => "Medium",
                    >= 50 => "Low",
                    _ => "Critical"
                };
                var confidenceColor = passRate switch
                {
                    >= 90 => "text-success",
                    >= 70 => "text-warning",
                    >= 50 => "text-danger",
                    _ => "text-danger"
                };
                var confidenceBg = passRate switch
                {
                    >= 90 => "bg-success",
                    >= 70 => "bg-warning",
                    >= 50 => "bg-danger",
                    _ => "bg-danger"
                };

                <div class="row mb-4">
                    <!-- Pie Chart Card -->
                    <div class="col-md-6 mb-3 mb-md-0">
                        <div class="card h-100">
                            <div class="card-header">
                                <h6 class="mb-0">@Model.Plan?.Name — Status</h6>
                            </div>
                            <div class="card-body d-flex align-items-center justify-content-center gap-4">
                                <div class="pie-chart"
                                     style="background: conic-gradient(
                                         var(--brand-teal) 0% @($"{passedPct:F1}")%,
                                         #dc3545 @($"{passedPct:F1}")% @($"{passedPct + failedPct:F1}")%,
                                         #ffc107 @($"{passedPct + failedPct:F1}")% @($"{passedPct + failedPct + blockedPct:F1}")%,
                                         #6c757d @($"{passedPct + failedPct + blockedPct:F1}")% 100%
                                     );">
                                </div>
                                <ul class="pie-chart-legend">
                                    <li>
                                        <span class="swatch" style="background-color: var(--brand-teal);"></span>
                                        Passed — @Model.Plan.PassedCount (@($"{passedPct:F0}")%)
                                    </li>
                                    <li>
                                        <span class="swatch" style="background-color: #dc3545;"></span>
                                        Failed — @Model.Plan.FailedCount (@($"{failedPct:F0}")%)
                                    </li>
                                    <li>
                                        <span class="swatch" style="background-color: #ffc107;"></span>
                                        Blocked — @Model.Plan.BlockedCount (@($"{blockedPct:F0}")%)
                                    </li>
                                    <li>
                                        <span class="swatch" style="background-color: #6c757d;"></span>
                                        Untested — @Model.Plan.UntestedCount (@($"{untestedPct:F0}")%)
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </div>

                    <!-- Confidence Window Card -->
                    <div class="col-md-6">
                        <div class="card h-100">
                            <div class="card-header">
                                <h6 class="mb-0">Confidence Window</h6>
                            </div>
                            <div class="card-body d-flex flex-column align-items-center justify-content-center text-center">
                                <div class="confidence-score @confidenceColor mb-1">@($"{passRate:F0}")%</div>
                                <div class="confidence-label @confidenceColor mb-3">@confidenceLevel Confidence</div>
                                <div class="w-100">
                                    <div class="d-flex justify-content-between small text-muted mb-1">
                                        <span>Completion</span>
                                        <span>@executedTests / @totalTests (@($"{completionRate:F0}")%)</span>
                                    </div>
                                    <div class="progress mb-3" style="height: 8px;">
                                        <div class="progress-bar @confidenceBg" role="progressbar"
                                             style="width: @($"{completionRate:F1}")%"></div>
                                    </div>
                                    <div class="row text-center">
                                        <div class="col">
                                            <div class="fw-bold text-success">@Model.Plan.PassedCount</div>
                                            <div class="text-muted small">Passed</div>
                                        </div>
                                        <div class="col">
                                            <div class="fw-bold text-danger">@Model.Plan.FailedCount</div>
                                            <div class="text-muted small">Failed</div>
                                        </div>
                                        <div class="col">
                                            <div class="fw-bold" style="color: #ffc107;">@Model.Plan.BlockedCount</div>
                                            <div class="text-muted small">Blocked</div>
                                        </div>
                                        <div class="col">
                                            <div class="fw-bold text-secondary">@Model.Plan.UntestedCount</div>
                                            <div class="text-muted small">Untested</div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }

        <div class="d-flex justify-content-between align-items-center mb-3">
            <h4 class="mb-0">Test Runs</h4>
            @if (Model.WritesEnabled && Model.Plan is not null && !Model.Plan.IsCompleted)
            {
                <button type="button" class="btn btn-success" data-bs-toggle="modal" data-bs-target="#addEntryModal">
                    + Add Test Run
                </button>
            }
        </div>

        @if (Model.Plan?.Entries is null || Model.Plan.Entries.Count == 0)
        {
            <div class="empty-state">
                <p class="text-muted mb-3">No test runs found in this test plan.</p>
                @if (Model.WritesEnabled && Model.Plan is not null && !Model.Plan.IsCompleted)
                {
                    <button type="button" class="btn btn-success" data-bs-toggle="modal" data-bs-target="#addEntryModal">
                        + Add Test Run
                    </button>
                }
            </div>
        }
        else
        {
            @foreach (var entry in Model.Plan.Entries)
            {
                @if (entry.Runs.Count == 0)
                {
                    <div class="card mb-4">
                        <div class="card-header d-flex justify-content-between align-items-center">
                            <strong>@entry.Name</strong>
                            @if (Model.WritesEnabled && !Model.Plan.IsCompleted)
                            {
                                <div class="d-flex gap-2">
                                    <button type="button" class="btn btn-sm btn-outline-secondary rename-entry-btn"
                                            data-bs-toggle="modal" data-bs-target="#renameEntryModal"
                                            data-entry-id="@entry.Id" data-entry-name="@entry.Name">
                                        Rename
                                    </button>
                                    <button type="button" class="btn btn-sm btn-outline-danger delete-entry-btn"
                                            data-bs-toggle="modal" data-bs-target="#deleteEntryModal"
                                            data-entry-id="@entry.Id" data-entry-name="@entry.Name">
                                        Delete
                                    </button>
                                </div>
                            }
                        </div>
                        <div class="card-body">
                            <p class="text-muted mb-0">No tests in this run.</p>
                        </div>
                    </div>
                }
                else
                {
                    @foreach (var run in entry.Runs)
                    {
                        var tests = Model.RunTests.GetValueOrDefault(run.Id, []);
                        var total = run.PassedCount + run.FailedCount + run.BlockedCount + run.UntestedCount;
                        <div class="card mb-4">
                            <div class="card-header">
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <div>
                                            <a asp-page="/Tests" asp-route-runId="@run.Id" class="text-decoration-none fw-bold">@run.Name</a>
                                            <span class="text-muted small ms-2">(Run ID: @run.Id)</span>
                                        </div>
                                        @if (Model.WritesEnabled && !Model.Plan.IsCompleted)
                                        {
                                            <div class="d-flex gap-2">
                                                <button type="button" class="btn btn-sm btn-outline-secondary rename-entry-btn"
                                                        data-bs-toggle="modal" data-bs-target="#renameEntryModal"
                                                        data-entry-id="@entry.Id" data-entry-name="@entry.Name">
                                                    Rename
                                                </button>
                                                <button type="button" class="btn btn-sm btn-outline-danger delete-entry-btn"
                                                        data-bs-toggle="modal" data-bs-target="#deleteEntryModal"
                                                        data-entry-id="@entry.Id" data-entry-name="@entry.Name">
                                                    Delete
                                                </button>
                                            </div>
                                        }
                                    </div>
                                    <div class="d-flex gap-2 flex-wrap">
                                        <span class="badge bg-success">@run.PassedCount Passed</span>
                                        <span class="badge bg-danger">@run.FailedCount Failed</span>
                                        <span class="badge bg-warning">@run.BlockedCount Blocked</span>
                                        <span class="badge bg-secondary">@run.UntestedCount Untested</span>
                                    </div>
                                @if (total > 0)
                                {
                                    <div class="progress mt-2" style="height: 8px;">
                                        <div class="progress-bar bg-success" role="progressbar"
                                             style="width: @($"{(double)run.PassedCount / total * 100:F1}")%"
                                             title="@run.PassedCount Passed"></div>
                                        <div class="progress-bar bg-danger" role="progressbar"
                                             style="width: @($"{(double)run.FailedCount / total * 100:F1}")%"
                                             title="@run.FailedCount Failed"></div>
                                        <div class="progress-bar bg-warning" role="progressbar"
                                             style="width: @($"{(double)run.BlockedCount / total * 100:F1}")%"
                                             title="@run.BlockedCount Blocked"></div>
                                        <div class="progress-bar bg-secondary" role="progressbar"
                                             style="width: @($"{(double)run.UntestedCount / total * 100:F1}")%"
                                             title="@run.UntestedCount Untested"></div>
                                    </div>
                                }
                            </div>
                            <div class="card-body p-0">
                                @if (tests.Count == 0)
                                {
                                    <p class="p-3 mb-0 text-muted">No tests found in this run.</p>
                                }
                                else
                                {
                                    <div class="table-responsive">
                                    <table class="table table-striped mb-0">
                                        <thead>
                                            <tr>
                                                <th class="sortable" data-sort-type="number">ID</th>
                                                <th class="sortable">Case ID</th>
                                                <th class="sortable">Title</th>
                                                <th class="sortable">Status</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var test in tests)
                                            {
                                                <tr>
                                                    <td>@test.Id</td>
                                                    <td>C@test.CaseId</td>
                                                    <td>@test.Title</td>
                                                    <td>
                                                        @{
                                                            var badgeClass = test.StatusId switch
                                                            {
                                                                1 => "bg-success",
                                                                2 => "bg-warning",
                                                                5 => "bg-danger",
                                                                _ => "bg-secondary"
                                                            };
                                                        }
                                                        <span class="badge @badgeClass">@test.StatusName</span>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                }
            }
        }
    </div>
</div>

<!-- Add Test Run Modal -->
<div class="modal fade" id="addEntryModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-page-handler="AddEntry" asp-route-planId="@Model.Plan?.Id" asp-antiforgery="true">
                <div class="modal-header">
                    <h5 class="modal-title">Add Test Run to Plan</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    @if (Model.Suites.Count <= 1)
                    {
                        <input type="hidden" name="EntrySuiteId" value="@Model.Suites.FirstOrDefault()?.Id" />
                    }
                    else
                    {
                        <div class="mb-3">
                            <label for="entrySuiteId" class="form-label">Test Case Source *</label>
                            <select name="EntrySuiteId" id="entrySuiteId" class="form-select" required>
                                <option value="">Select a source...</option>
                                @foreach (var suite in Model.Suites)
                                {
                                    <option value="@suite.Id">@suite.Name</option>
                                }
                            </select>
                        </div>
                    }
                    <div class="mb-3">
                        <label for="entryName" class="form-label">Run Name</label>
                        <input type="text" name="EntryName" id="entryName" class="form-control" placeholder="Optional — auto-generated if empty" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success">Add Test Run</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Rename Test Run Modal -->
<div class="modal fade" id="renameEntryModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-page-handler="RenameEntry" asp-route-planId="@Model.Plan?.Id" asp-antiforgery="true">
                <div class="modal-header">
                    <h5 class="modal-title">Rename Test Run</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="RenameEntryId" id="renameEntryId" />
                    <div class="mb-3">
                        <label for="renameEntryName" class="form-label">New Name *</label>
                        <input type="text" name="RenameEntryName" id="renameEntryName" class="form-control" required />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Delete Test Run Confirmation Modal -->
<div class="modal fade" id="deleteEntryModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-page-handler="DeleteEntry" asp-route-planId="@Model.Plan?.Id" asp-antiforgery="true">
                <div class="modal-header">
                    <h5 class="modal-title">Delete Test Run</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="DeleteEntryId" id="deleteEntryId" />
                    <p>Are you sure you want to delete <strong id="deleteEntryName"></strong>?</p>
                    <p class="text-danger small mb-0">This action cannot be undone. All test results in this run will be permanently deleted.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger">Delete</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('renameEntryModal')?.addEventListener('show.bs.modal', function (event) {
            var button = event.relatedTarget;
            document.getElementById('renameEntryId').value = button.getAttribute('data-entry-id');
            document.getElementById('renameEntryName').value = button.getAttribute('data-entry-name');
        });

        document.getElementById('deleteEntryModal')?.addEventListener('show.bs.modal', function (event) {
            var button = event.relatedTarget;
            document.getElementById('deleteEntryId').value = button.getAttribute('data-entry-id');
            document.getElementById('deleteEntryName').textContent = button.getAttribute('data-entry-name');
        });
    </script>
}
