@inject TestRailNavigator.Services.SettingsService SettingsService
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TestRailNavigator</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/TestRailNavigator.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark border-bottom box-shadow mb-3" style="background-color: var(--brand-dark, #1a1a1a);">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" asp-area="" asp-page="/Index">
                    <span style="color: var(--brand-teal);">Test</span>RailNavigator
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Privacy">Privacy</a>
                        </li>
                    </ul>
                    <ul class="navbar-nav align-items-center">
                        <li class="nav-item">
                            <a class="nav-link d-flex align-items-center gap-2" asp-area="" asp-page="/Setup">
                                <i class="bi bi-gear"></i>
                                @if (await SettingsService.IsConfiguredAsync())
                                {
                                    @if (await SettingsService.AreWritesEnabledAsync())
                                    {
                                        <span class="navbar-mode-dot bg-success" title="Read / Write"></span>
                                    }
                                    else
                                    {
                                        <span class="navbar-mode-dot bg-warning" title="Read-Only"></span>
                                    }
                                }
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container-fluid px-4">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer py-3" style="background-color: var(--brand-dark, #1a1a1a); color: rgba(255,255,255,.6);">
        <div class="container-fluid px-4">
            &copy; 2026 - TestRailNavigator - <a asp-area="" asp-page="/Privacy" style="color: var(--brand-teal);">Privacy</a>
        </div>
    </footer>

    <environment include="Development">
        @await Html.PartialAsync("_ConsoleWindow")
    </environment>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/sortable.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
