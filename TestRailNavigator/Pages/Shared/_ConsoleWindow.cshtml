@inject TestRailNavigator.Services.ConsoleLogService ConsoleLogService
@{
    var messages = ConsoleLogService.GetMessages();
}
<div style="position:fixed; left:0; right:0; bottom:0; height:25vh; background:#1e1e1e; color:#dcdcdc; z-index:9999; font-family:'Cascadia Mono',Consolas,monospace; font-size:0.85em; border-top:2px solid #007acc;">
    <div style="padding:4px 12px; background:#007acc; color:#fff; font-weight:bold;">
        Console Window
    </div>
    <div id="consoleOutput" style="padding:8px 12px; height:calc(25vh - 30px); overflow-y:auto;">
        @if (!messages.Any())
        {
            <div style="color:#6a9955;">No messages.</div>
        }
        else
        {
            @foreach (var msg in messages)
            {
                <div style="color:#f44747;">@msg</div>
            }
        }
    </div>
</div>
<style>
    body { padding-bottom: 25vh; }
</style>
