@page "{projectId:int}"
@model ProjectModel
@{
    ViewData["Title"] = Model.Project?.Name ?? "Project";
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-page="/Index">Projects</a></li>
        @if (Model.SelectedMilestone is not null)
        {
            <li class="breadcrumb-item"><a asp-page="/Project" asp-route-projectId="@Model.Project?.Id">@Model.Project?.Name</a></li>
            @if (Model.ParentMilestone is not null)
            {
                <li class="breadcrumb-item"><a asp-page="/Project" asp-route-projectId="@Model.Project?.Id" asp-route-milestoneId="@Model.ParentMilestone.Id">@Model.ParentMilestone.Name</a></li>
            }
            <li class="breadcrumb-item active">@Model.SelectedMilestone.Name</li>
        }
        else
        {
            <li class="breadcrumb-item active">@Model.Project?.Name</li>
        }
    </ol>
</nav>

<h1>@Model.Project?.Name</h1>
@if (!string.IsNullOrEmpty(Model.Project?.Announcement))
{
    <p class="text-muted">@Model.Project.Announcement</p>
}

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="alert alert-success alert-dismissible fade show">
        @Model.SuccessMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger alert-dismissible fade show">
        @Model.ErrorMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (Model.Project is not null)
{
    <div class="row">
        <!-- Left Panel: Milestones -->
        <div class="col-lg-3 col-md-4 mb-4">
            <div class="card h-100">
                <div class="card-header">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h6 class="mb-0">Milestones</h6>
                        <a asp-page="/Milestones" asp-route-projectId="@Model.Project.Id" class="btn btn-sm btn-outline-info">
                            Manage
                        </a>
                    </div>
                    <select id="milestoneFilter" class="form-select form-select-sm">
                        <option value="active" selected>Active</option>
                        <option value="upcoming">Upcoming</option>
                        <option value="completed">Completed</option>
                        <option value="all">All</option>
                    </select>
                </div>
                <div class="card-body p-0" style="overflow-y: auto; max-height: 70vh;">
                    <div class="list-group list-group-flush" id="milestoneList">
                        @{
                            var allParents = Model.OpenMilestones.Concat(Model.ClosedMilestones).OrderBy(m => m.Name).ToList();
                        }
                        @if (allParents.Count == 0)
                        {
                            <p class="text-muted small px-3 py-2 mb-0">No milestones found.</p>
                        }
                        @foreach (var milestone in allParents)
                        {
                            var isSelected = Model.MilestoneId == milestone.Id;
                            var status = milestone.IsCompleted ? "completed" : milestone.IsStarted ? "active" : "upcoming";
                            <a asp-page="/Project" asp-route-projectId="@Model.Project.Id" asp-route-milestoneId="@milestone.Id"
                               class="list-group-item list-group-item-action px-3 py-2 milestone-item @(isSelected ? "active" : "")"
                               data-status="@status" data-milestone-id="@milestone.Id">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        <div class="fw-semibold @(milestone.IsCompleted && !isSelected ? "text-muted" : "")">@milestone.Name</div>
                                        @if (milestone.IsCompleted && milestone.CompletedOn.HasValue)
                                        {
                                            <small class="@(isSelected ? "text-white-50" : "text-muted")">
                                                Completed @DateTimeOffset.FromUnixTimeSeconds(milestone.CompletedOn.Value).UtcDateTime.ToString("yyyy-MM-dd")
                                            </small>
                                        }
                                        else if (milestone.DueOn.HasValue)
                                        {
                                            <small class="@(isSelected ? "text-white-50" : "text-muted")">
                                                Due @DateTimeOffset.FromUnixTimeSeconds(milestone.DueOn.Value).UtcDateTime.ToString("yyyy-MM-dd")
                                            </small>
                                        }
                                    </div>
                                    @if (milestone.IsCompleted)
                                    {
                                        <span class="badge @(isSelected ? "bg-light text-dark" : "bg-secondary")">Completed</span>
                                    }
                                    else if (milestone.IsStarted)
                                    {
                                        <span class="badge @(isSelected ? "bg-light text-dark" : "bg-success")">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge @(isSelected ? "bg-light text-dark" : "bg-info")">Upcoming</span>
                                    }
                                </div>
                            </a>
                            @if (Model.MilestoneChildren.TryGetValue(milestone.Id, out var children))
                            {
                                @foreach (var child in children)
                                {
                                    var isChildSelected = Model.MilestoneId == child.Id;
                                    var childStatus = child.IsCompleted ? "completed" : child.IsStarted ? "active" : "upcoming";
                                    <a asp-page="/Project" asp-route-projectId="@Model.Project.Id" asp-route-milestoneId="@child.Id"
                                       class="list-group-item list-group-item-action ps-5 py-1 milestone-child @(isChildSelected ? "active" : "")"
                                       data-parent-id="@milestone.Id" data-status="@childStatus">
                                        <div class="d-flex justify-content-between align-items-start">
                                            <div>
                                                <div class="small @(isChildSelected ? "" : child.IsCompleted ? "text-muted" : "")">@child.Name</div>
                                            </div>
                                            @if (child.IsCompleted)
                                            {
                                                <span class="badge @(isChildSelected ? "bg-light text-dark" : "bg-secondary") badge-sm">Done</span>
                                            }
                                            else if (child.IsStarted)
                                            {
                                                <span class="badge @(isChildSelected ? "bg-light text-dark" : "bg-success") badge-sm">Active</span>
                                            }
                                        </div>
                                    </a>
                                }
                            }
                        }
                    </div>
                    <p class="text-muted small px-3 py-2 mb-0 d-none" id="milestoneEmpty">No milestones match this filter.</p>
                </div>
            </div>
        </div>

        <!-- Right Side: Milestone Content -->
        <div class="col-lg-9 col-md-8">
            @if (Model.SelectedMilestone is null)
            {
                <div class="d-flex align-items-center justify-content-center h-100">
                    <div class="text-center text-muted">
                        <h3><i class="bi bi-arrow-left-circle"></i></h3>
                        <h4>Select a Milestone</h4>
                        <p>Choose a milestone from the panel on the left to view its test plans and test runs.</p>
                    </div>
                </div>
            }
            else
            {
                <h3 class="mb-4">
                    @if (Model.ParentMilestone is not null)
                    {
                        <span class="text-muted fw-semibold">@Model.ParentMilestone.Name →</span>
                    }
                    @Model.SelectedMilestone.Name
                </h3>

                @if (Model.SelectedChildMilestones.Count > 0)
                {
                    var activeMilestones = Model.SelectedChildMilestones.Where(m => !m.IsCompleted && m.IsStarted).ToList();
                    var upcomingMilestones = Model.SelectedChildMilestones.Where(m => !m.IsCompleted && !m.IsStarted).ToList();
                    var completedMilestones = Model.SelectedChildMilestones.Where(m => m.IsCompleted).ToList();

                    <!-- Milestones Section (child milestones) -->
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h4 class="mb-0">Milestones</h4>
                        @if (Model.WritesEnabled)
                        {
                            <button type="button" class="btn btn-success" data-bs-toggle="modal" data-bs-target="#createChildMilestoneModal">
                                + New Child Milestone
                            </button>
                        }
                    </div>

                    @if (activeMilestones.Count > 0)
                    {
                        <h6 class="text-uppercase text-muted small fw-bold mb-2">
                            Active
                            <span class="badge bg-success ms-1">@activeMilestones.Count</span>
                        </h6>
                        <div class="table-responsive mb-4">
                        <table class="table table-striped child-milestone-table">
                            <thead>
                                <tr>
                                    <th class="sortable" data-sort-type="number">ID</th>
                                    <th class="sortable">Name</th>
                                    <th class="sortable" data-sort-type="date">Start Date</th>
                                    <th class="sortable" data-sort-type="date">Due Date</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var child in activeMilestones)
                                {
                                    <tr>
                                        <td>@child.Id</td>
                                        <td>
                                            <a asp-page="/Project" asp-route-projectId="@Model.Project.Id" asp-route-milestoneId="@child.Id">
                                                @child.Name
                                            </a>
                                        </td>
                                        <td>
                                            @if (child.StartOn.HasValue)
                                            {
                                                @DateTimeOffset.FromUnixTimeSeconds(child.StartOn.Value).UtcDateTime.ToString("yyyy-MM-dd")
                                            }
                                            else
                                            {
                                                <span class="text-muted">—</span>
                                            }
                                        </td>
                                        <td>
                                            @if (child.DueOn.HasValue)
                                            {
                                                @DateTimeOffset.FromUnixTimeSeconds(child.DueOn.Value).UtcDateTime.ToString("yyyy-MM-dd")
                                            }
                                            else
                                            {
                                                <span class="text-muted">—</span>
                                            }
                                        </td>
                                        <td>
                                            @if (Model.WritesEnabled)
                                            {
                                                <button type="button" class="btn btn-sm btn-outline-primary"
                                                        data-bs-toggle="modal"
                                                        data-bs-target="#editChildMilestoneModal"
                                                        data-id="@child.Id"
                                                        data-name="@child.Name"
                                                        data-description="@child.Description"
                                                        data-start="@(child.StartOn.HasValue ? DateTimeOffset.FromUnixTimeSeconds(child.StartOn.Value).UtcDateTime.ToString("yyyy-MM-dd") : "")"
                                                        data-due="@(child.DueOn.HasValue ? DateTimeOffset.FromUnixTimeSeconds(child.DueOn.Value).UtcDateTime.ToString("yyyy-MM-dd") : "")"
                                                        data-completed="@child.IsCompleted.ToString().ToLowerInvariant()">
                                                    Edit
                                                </button>
                                                <button type="button" class="btn btn-sm btn-outline-danger"
                                                        data-bs-toggle="modal"
                                                        data-bs-target="#deleteChildMilestoneModal"
                                                        data-id="@child.Id"
                                                        data-name="@child.Name">
                                                    Delete
                                                </button>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                        </div>
                    }

                    @if (upcomingMilestones.Count > 0)
                    {
                        <h6 class="text-uppercase text-muted small fw-bold mb-2">
                            Upcoming
                            <span class="badge bg-info ms-1">@upcomingMilestones.Count</span>
                        </h6>
                        <div class="table-responsive mb-4">
                        <table class="table table-striped child-milestone-table">
                            <thead>
                                <tr>
                                    <th class="sortable" data-sort-type="number">ID</th>
                                    <th class="sortable">Name</th>
                                    <th class="sortable" data-sort-type="date">Start Date</th>
                                    <th class="sortable" data-sort-type="date">Due Date</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var child in upcomingMilestones)
                                {
                                    <tr>
                                        <td>@child.Id</td>
                                        <td>
                                            <a asp-page="/Project" asp-route-projectId="@Model.Project.Id" asp-route-milestoneId="@child.Id">
                                                @child.Name
                                            </a>
                                        </td>
                                        <td>
                                            @if (child.StartOn.HasValue)
                                            {
                                                @DateTimeOffset.FromUnixTimeSeconds(child.StartOn.Value).UtcDateTime.ToString("yyyy-MM-dd")
                                            }
                                            else
                                            {
                                                <span class="text-muted">—</span>
                                            }
                                        </td>
                                        <td>
                                            @if (child.DueOn.HasValue)
                                            {
                                                @DateTimeOffset.FromUnixTimeSeconds(child.DueOn.Value).UtcDateTime.ToString("yyyy-MM-dd")
                                            }
                                            else
                                            {
                                                <span class="text-muted">—</span>
                                            }
                                        </td>
                                        <td>
                                            @if (Model.WritesEnabled)
                                            {
                                                <button type="button" class="btn btn-sm btn-outline-primary"
                                                        data-bs-toggle="modal"
                                                        data-bs-target="#editChildMilestoneModal"
                                                        data-id="@child.Id"
                                                        data-name="@child.Name"
                                                        data-description="@child.Description"
                                                        data-start="@(child.StartOn.HasValue ? DateTimeOffset.FromUnixTimeSeconds(child.StartOn.Value).UtcDateTime.ToString("yyyy-MM-dd") : "")"
                                                        data-due="@(child.DueOn.HasValue ? DateTimeOffset.FromUnixTimeSeconds(child.DueOn.Value).UtcDateTime.ToString("yyyy-MM-dd") : "")"
                                                        data-completed="@child.IsCompleted.ToString().ToLowerInvariant()">
                                                    Edit
                                                </button>
                                                <button type="button" class="btn btn-sm btn-outline-danger"
                                                        data-bs-toggle="modal"
                                                        data-bs-target="#deleteChildMilestoneModal"
                                                        data-id="@child.Id"
                                                        data-name="@child.Name">
                                                    Delete
                                                </button>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                        </div>
                    }

                    @if (completedMilestones.Count > 0)
                    {
                        <h6 class="text-uppercase text-muted small fw-bold mb-2">
                            Completed
                            <span class="badge bg-secondary ms-1">@completedMilestones.Count</span>
                        </h6>
                        <div class="table-responsive mb-4">
                        <table class="table table-striped child-milestone-table">
                            <thead>
                                <tr>
                                    <th class="sortable" data-sort-type="number">ID</th>
                                    <th class="sortable">Name</th>
                                    <th class="sortable" data-sort-type="date">Start Date</th>
                                    <th class="sortable" data-sort-type="date">Due Date</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var child in completedMilestones)
                                {
                                    <tr>
                                        <td>@child.Id</td>
                                        <td>
                                            <a asp-page="/Project" asp-route-projectId="@Model.Project.Id" asp-route-milestoneId="@child.Id">
                                                @child.Name
                                            </a>
                                        </td>
                                        <td>
                                            @if (child.StartOn.HasValue)
                                            {
                                                @DateTimeOffset.FromUnixTimeSeconds(child.StartOn.Value).UtcDateTime.ToString("yyyy-MM-dd")
                                            }
                                            else
                                            {
                                                <span class="text-muted">—</span>
                                            }
                                        </td>
                                        <td>
                                            @if (child.DueOn.HasValue)
                                            {
                                                @DateTimeOffset.FromUnixTimeSeconds(child.DueOn.Value).UtcDateTime.ToString("yyyy-MM-dd")
                                            }
                                            else
                                            {
                                                <span class="text-muted">—</span>
                                            }
                                        </td>
                                        <td>
                                            @if (Model.WritesEnabled)
                                            {
                                                <button type="button" class="btn btn-sm btn-outline-primary"
                                                        data-bs-toggle="modal"
                                                        data-bs-target="#editChildMilestoneModal"
                                                        data-id="@child.Id"
                                                        data-name="@child.Name"
                                                        data-description="@child.Description"
                                                        data-start="@(child.StartOn.HasValue ? DateTimeOffset.FromUnixTimeSeconds(child.StartOn.Value).UtcDateTime.ToString("yyyy-MM-dd") : "")"
                                                        data-due="@(child.DueOn.HasValue ? DateTimeOffset.FromUnixTimeSeconds(child.DueOn.Value).UtcDateTime.ToString("yyyy-MM-dd") : "")"
                                                        data-completed="@child.IsCompleted.ToString().ToLowerInvariant()">
                                                    Edit
                                                </button>
                                                <button type="button" class="btn btn-sm btn-outline-danger"
                                                        data-bs-toggle="modal"
                                                        data-bs-target="#deleteChildMilestoneModal"
                                                        data-id="@child.Id"
                                                        data-name="@child.Name">
                                                    Delete
                                                </button>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                        </div>
                    }

                    <hr class="my-4" />
                }

                <!-- Test Plans Section -->
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h4 class="mb-0">Test Plans</h4>
                    @if (Model.WritesEnabled)
                    {
                        <button type="button" class="btn btn-success" data-bs-toggle="modal" data-bs-target="#createPlanModal">
                            + New Test Plan
                        </button>
                    }
                </div>

                @if (Model.MilestonePlans.Count == 0)
                {
                    <p class="text-muted">No test plans found for this milestone.</p>
                }
                else
                {
                    <div class="table-responsive">
                    <table class="table table-striped milestone-table">
                        <thead>
                            <tr>
                                <th class="sortable" data-sort-type="number">ID</th>
                                <th class="sortable">Name</th>
                                <th class="sortable">Status</th>
                                <th class="sortable" data-sort-type="number">Passed</th>
                                <th class="sortable" data-sort-type="number">Failed</th>
                                <th class="sortable" data-sort-type="number">Blocked</th>
                                <th class="sortable" data-sort-type="number">Untested</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var plan in Model.MilestonePlans)
                            {
                                <tr>
                                    <td>@plan.Id</td>
                                    <td>
                                        <a asp-page="/PlanDetail" asp-route-planId="@plan.Id">@plan.Name</a>
                                    </td>
                                    <td>
                                        @if (plan.IsCompleted)
                                        {
                                            <span class="badge bg-secondary">Completed</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">Active</span>
                                        }
                                    </td>
                                    <td><span class="text-success">@plan.PassedCount</span></td>
                                    <td><span class="text-danger">@plan.FailedCount</span></td>
                                    <td><span class="text-warning">@plan.BlockedCount</span></td>
                                    <td><span class="text-muted">@plan.UntestedCount</span></td>
                                    <td>
                                        @if (Model.WritesEnabled)
                                        {
                                            @if (!plan.IsCompleted)
                                            {
                                                <button type="button" class="btn btn-sm btn-outline-primary"
                                                        data-bs-toggle="modal"
                                                        data-bs-target="#editPlanModal"
                                                        data-id="@plan.Id"
                                                        data-name="@plan.Name"
                                                        data-description="@plan.Description">
                                                    Edit
                                                </button>
                                                <button type="button" class="btn btn-sm btn-outline-secondary"
                                                        data-bs-toggle="modal"
                                                        data-bs-target="#closePlanModal"
                                                        data-id="@plan.Id"
                                                        data-name="@plan.Name">
                                                    Close
                                                </button>
                                            }
                                            <button type="button" class="btn btn-sm btn-outline-danger"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#deletePlanModal"
                                                    data-id="@plan.Id"
                                                    data-name="@plan.Name">
                                                Delete
                                            </button>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    </div>
                }

                <hr class="my-4" />

                <!-- Test Runs Section -->
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h4 class="mb-0">Test Runs</h4>
                    @if (Model.WritesEnabled)
                    {
                        <button type="button" class="btn btn-success" data-bs-toggle="modal" data-bs-target="#createRunModal">
                            + New Test Run
                        </button>
                    }
                </div>

                @if (Model.MilestoneRuns.Count == 0)
                {
                    <p class="text-muted">No test runs found for this milestone.</p>
                }
                else
                {
                    <div class="table-responsive">
                    <table class="table table-striped milestone-table">
                        <thead>
                            <tr>
                                <th class="sortable" data-sort-type="number">ID</th>
                                <th class="sortable">Name</th>
                                <th class="sortable">Status</th>
                                <th class="sortable" data-sort-type="number">Passed</th>
                                <th class="sortable" data-sort-type="number">Failed</th>
                                <th class="sortable" data-sort-type="number">Blocked</th>
                                <th class="sortable" data-sort-type="number">Untested</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var run in Model.MilestoneRuns)
                            {
                                <tr>
                                    <td>@run.Id</td>
                                    <td>
                                        <a asp-page="/Tests" asp-route-runId="@run.Id">@run.Name</a>
                                    </td>
                                    <td>
                                        @if (run.IsCompleted)
                                        {
                                            <span class="badge bg-secondary">Completed</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">Active</span>
                                        }
                                    </td>
                                    <td><span class="text-success">@run.PassedCount</span></td>
                                    <td><span class="text-danger">@run.FailedCount</span></td>
                                    <td><span class="text-warning">@run.BlockedCount</span></td>
                                    <td><span class="text-muted">@run.UntestedCount</span></td>
                                    <td>
                                        @if (Model.WritesEnabled)
                                        {
                                            @if (!run.IsCompleted)
                                            {
                                                <button type="button" class="btn btn-sm btn-outline-primary"
                                                        data-bs-toggle="modal"
                                                        data-bs-target="#editRunModal"
                                                        data-id="@run.Id"
                                                        data-name="@run.Name"
                                                        data-description="@run.Description">
                                                    Edit
                                                </button>
                                                <button type="button" class="btn btn-sm btn-outline-secondary"
                                                        data-bs-toggle="modal"
                                                        data-bs-target="#closeRunModal"
                                                        data-id="@run.Id"
                                                        data-name="@run.Name">
                                                    Close
                                                </button>
                                            }
                                            <button type="button" class="btn btn-sm btn-outline-danger"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#deleteRunModal"
                                                    data-id="@run.Id"
                                                    data-name="@run.Name">
                                                Delete
                                            </button>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    </div>
                }
            }
        </div>
    </div>
}

<!-- Create Test Plan Modal -->
<div class="modal fade" id="createPlanModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-page-handler="CreatePlan" asp-route-projectId="@Model.Project?.Id" asp-route-milestoneId="@Model.MilestoneId" asp-antiforgery="true">
                <input type="hidden" name="MilestoneId" value="@Model.MilestoneId" />
                <div class="modal-header">
                    <h5 class="modal-title">Create New Test Plan</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="createPlanName" class="form-label">Name *</label>
                        <input type="text" name="PlanName" id="createPlanName" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label for="createPlanDescription" class="form-label">Description</label>
                        <textarea name="PlanDescription" id="createPlanDescription" class="form-control" rows="3"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success">Create Plan</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Test Plan Modal -->
<div class="modal fade" id="editPlanModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-page-handler="EditPlan" asp-route-projectId="@Model.Project?.Id" asp-route-milestoneId="@Model.MilestoneId" asp-antiforgery="true">
                <input type="hidden" name="PlanId" id="editPlanId" />
                <input type="hidden" name="MilestoneId" value="@Model.MilestoneId" />
                <div class="modal-header">
                    <h5 class="modal-title">Edit Test Plan</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
