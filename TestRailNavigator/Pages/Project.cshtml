@section Scripts {
    <script>
        // Milestone sidebar filter
        const milestoneFilter = document.getElementById('milestoneFilter');
        const milestoneList = document.getElementById('milestoneList');
        const milestoneEmpty = document.getElementById('milestoneEmpty');

        function applyMilestoneFilter() {
            const filter = milestoneFilter.value;
            const parents = milestoneList.querySelectorAll('.milestone-item');
            const children = milestoneList.querySelectorAll('.milestone-child');
            let visibleCount = 0;

            parents.forEach(function (item) {
                const status = item.getAttribute('data-status');
                const show = filter === 'all' || status === filter;
                item.classList.toggle('d-none', !show);
                if (show) visibleCount++;
            });

            children.forEach(function (item) {
                const parentId = item.getAttribute('data-parent-id');
                const childStatus = item.getAttribute('data-status');
                const parent = milestoneList.querySelector('.milestone-item[data-milestone-id="' + parentId + '"]');
                const parentVisible = parent && !parent.classList.contains('d-none');
                const statusMatch = filter === 'all' || childStatus === filter;
                item.classList.toggle('d-none', !(parentVisible && statusMatch));
            });

            if (milestoneEmpty) {
                milestoneEmpty.classList.toggle('d-none', visibleCount > 0);
            }
        }

        if (milestoneFilter) {
            // If the selected milestone doesn't match the default filter, switch to its status
            const selectedItem = milestoneList && milestoneList.querySelector('.milestone-item.active');
            if (selectedItem) {
                const selectedStatus = selectedItem.getAttribute('data-status');
                if (selectedStatus !== milestoneFilter.value) {
                    milestoneFilter.value = selectedStatus;
                }
            }

            milestoneFilter.addEventListener('change', applyMilestoneFilter);
            applyMilestoneFilter();
        }

        // Populate the Edit Plan modal fields from data attributes on the trigger button
        const editPlanModal = document.getElementById('editPlanModal');
        if (editPlanModal) {
            editPlanModal.addEventListener('show.bs.modal', function (event) {
                const btn = event.relatedTarget;
                editPlanModal.querySelector('#editPlanId').value = btn.getAttribute('data-id');
                editPlanModal.querySelector('#editPlanName').value = btn.getAttribute('data-name');
                editPlanModal.querySelector('#editPlanDescription').value = btn.getAttribute('data-description') || '';
            });
        }

        // Populate the Delete Plan modal fields from data attributes on the trigger button
        const deletePlanModal = document.getElementById('deletePlanModal');
        if (deletePlanModal) {
            deletePlanModal.addEventListener('show.bs.modal', function (event) {
                const btn = event.relatedTarget;
                deletePlanModal.querySelector('#deletePlanId').value = btn.getAttribute('data-id');
                deletePlanModal.querySelector('#deletePlanName').textContent = btn.getAttribute('data-name');
            });
        }

        // Populate the Edit Run modal fields from data attributes on the trigger button
        const editRunModal = document.getElementById('editRunModal');
        if (editRunModal) {
            editRunModal.addEventListener('show.bs.modal', function (event) {
                const btn = event.relatedTarget;
                editRunModal.querySelector('#editRunId').value = btn.getAttribute('data-id');
                editRunModal.querySelector('#editRunName').value = btn.getAttribute('data-name');
                editRunModal.querySelector('#editRunDescription').value = btn.getAttribute('data-description') || '';
            });
        }

        // Populate the Delete Run modal fields from data attributes on the trigger button
        const deleteRunModal = document.getElementById('deleteRunModal');
        if (deleteRunModal) {
            deleteRunModal.addEventListener('show.bs.modal', function (event) {
                const btn = event.relatedTarget;
                deleteRunModal.querySelector('#deleteRunId').value = btn.getAttribute('data-id');
                deleteRunModal.querySelector('#deleteRunName').textContent = btn.getAttribute('data-name');
            });
        }

        // Populate the Close Plan modal fields from data attributes on the trigger button
        const closePlanModal = document.getElementById('closePlanModal');
        if (closePlanModal) {
            closePlanModal.addEventListener('show.bs.modal', function (event) {
                const btn = event.relatedTarget;
                closePlanModal.querySelector('#closePlanId').value = btn.getAttribute('data-id');
                closePlanModal.querySelector('#closePlanName').textContent = btn.getAttribute('data-name');
            });
        }

        // Populate the Close Run modal fields from data attributes on the trigger button
        const closeRunModal = document.getElementById('closeRunModal');
        if (closeRunModal) {
            closeRunModal.addEventListener('show.bs.modal', function (event) {
                const btn = event.relatedTarget;
                closeRunModal.querySelector('#closeRunId').value = btn.getAttribute('data-id');
                closeRunModal.querySelector('#closeRunName').textContent = btn.getAttribute('data-name');
            });
        }

        // Populate the Edit Child Milestone modal fields from data attributes on the trigger button
        const editChildMilestoneModal = document.getElementById('editChildMilestoneModal');
        if (editChildMilestoneModal) {
            editChildMilestoneModal.addEventListener('show.bs.modal', function (event) {
                const btn = event.relatedTarget;
                editChildMilestoneModal.querySelector('#editChildMilestoneId').value = btn.getAttribute('data-id');
                editChildMilestoneModal.querySelector('#editChildMilestoneName').value = btn.getAttribute('data-name');
                editChildMilestoneModal.querySelector('#editChildMilestoneDescription').value = btn.getAttribute('data-description') || '';
                editChildMilestoneModal.querySelector('#editChildMilestoneStart').value = btn.getAttribute('data-start') || '';
                editChildMilestoneModal.querySelector('#editChildMilestoneDue').value = btn.getAttribute('data-due') || '';
                editChildMilestoneModal.querySelector('#editChildMilestoneIsCompleted').checked = btn.getAttribute('data-completed') === 'true';
            });
        }

        // Populate the Delete Child Milestone modal fields from data attributes on the trigger button
        const deleteChildMilestoneModal = document.getElementById('deleteChildMilestoneModal');
        if (deleteChildMilestoneModal) {
            deleteChildMilestoneModal.addEventListener('show.bs.modal', function (event) {
                const btn = event.relatedTarget;
                deleteChildMilestoneModal.querySelector('#deleteChildMilestoneId').value = btn.getAttribute('data-id');
                deleteChildMilestoneModal.querySelector('#deleteChildMilestoneName').textContent = btn.getAttribute('data-name');
            });
        }
    </script>
}
